# Copie para .env e ajuste.  cp .env.example .env
# NÃO commitar o .env (contém senha).

# --- Versão da imagem WSFTP (no ECR) ---
# Fixe a versão para deploy reproduzível e rollback. Use "latest" só em teste.
WSFTP_VERSION=2.7.3

# --- Portas expostas no servidor ---
WSFTP_WEB_PORT=8031      # painel web
WSFTP_SFTP_PORT=1222     # SFTP/SSH

# --- Admin inicial (criado no primeiro start) ---
WSFTP_ADMIN_USER=wlasaas
WSFTP_ADMIN_PASSWORD=troque-esta-senha

# --- AWS / ECR (fornecido pela WLA) ---
AWS_REGION=sa-east-1
ECR_REGISTRY=091448068257.dkr.ecr.sa-east-1.amazonaws.com
